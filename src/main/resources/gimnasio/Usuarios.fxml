            <TextField prefHeight="40.0" prefWidth="350.0" promptText="Busca en Olimpo" style="-fx-background-color: #1a1a1a; -fx-text-fill: white; -fx-background-radius: 20; -fx-border-color: #333; -fx-border-radius: 20;" />
