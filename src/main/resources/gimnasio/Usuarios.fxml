<AnchorPane prefHeight="1080.0" prefWidth="1920.0" style="-fx-background-color: #050505;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gimnasio.UsuarioFormularioController">
